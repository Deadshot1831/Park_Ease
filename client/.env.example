# ParkEase Client Environment Variables
# Copy to .env and fill in your values

# Backend API base URL
VITE_API_URL=http://localhost:5000/api

# Socket.IO server URL (defaults to API URL without /api)
VITE_SOCKET_URL=http://localhost:5000

# Google Maps JavaScript API key (Maps JS + Places enabled).
# If omitted, the app falls back to a list view instead of the interactive map.
VITE_GOOGLE_MAPS_API_KEY=
